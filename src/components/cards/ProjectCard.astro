---
import type { ImageMetadata } from 'astro';
import Image from '@/components/Image.astro';

import HoverCard from './HoverCard.astro';
import { TAG_CONFIG } from '@/consts';

interface Props {
  name: string;
  href?: string;
  src: ImageMetadata | string;
  description: string;
  year: string;
  size?: 1 | 2 | 3;
  hideMobile?: boolean;
  containImage?: boolean;
  containBackgroundColor?: string;
  source?: string;
  tags?: string[];
}

const {
  name,
  href,
  src,
  description,
  year,
  size = 1,
  hideMobile = false,
  containImage = false,
  containBackgroundColor,
  source,
  tags = []
} = Astro.props;
---

<HoverCard
  class:list={['project-card', { 'col-span-1': size === 1, 'col-span-2': size === 2, 'col-span-3': size === 3, 'hidden sm:block': hideMobile }]}
  data-tags={tags.join(',')}
>
  <div class="bg-bkg absolute inset-0" style={`background-color: ${containBackgroundColor};`}>
    {
      !containImage && typeof src !== 'string' ? (
        <Image
          {src}
          alt=""
          class="absolute h-full w-full object-cover object-top transition-transform group-hover:scale-105"
          widths={[100, 300, 600]}
          sizes="(max-width: 600px) 100vw, (max-width: 1024px) 66vw, 33vw"
          quality={60}
        />
      ) : typeof src !== 'string' ? (
        <Image
          {src}
          alt=""
          class="absolute h-full w-full rotate-2 object-contain p-4 drop-shadow-lg transition-transform group-hover:scale-105 group-hover:-rotate-3"
          widths={[100, 300, 600]}
          sizes="(max-width: 600px) 100vw, (max-width: 1024px) 66vw, 33vw"
          quality={60}
        />
      ) : !containImage ? (
        <img src={src} alt="" class="absolute h-full w-full object-contain p-4 drop-shadow-lg transition-transform group-hover:scale-105" />
      ) : (
        <img
          src={src}
          alt=""
          class="absolute h-full w-full rotate-2 object-contain p-4 drop-shadow-lg transition-transform group-hover:scale-105 group-hover:-rotate-3"
        />
      )
    }
    <div
      class="can-hover:group-hover:-translate-y-full relative top-full mx-auto flex h-full w-full -translate-y-6 flex-col justify-center rounded-lg shadow-lg motion-safe:duration-200"
    >
      <span
        class="bg-bkg/90 absolute top-1 right-5 h-4 rounded-t-lg px-4 text-left align-top text-sm font-semibold text-slate-900 italic backdrop-blur-sm dark:text-white"
      >
        {year}
      </span>
      <div class="bg-bkg/90 absolute top-5 right-0 bottom-0 left-0 rounded-lg backdrop-blur-sm"></div>
      <div
        class:list={[
          'absolute top-4 right-0 bottom-0 left-0 flex flex-col items-center gap-2 overflow-y-auto mask-t-from-80% pt-4',
          size === 1 ? 'px-1' : 'px-4'
        ]}
      >
        <h3 class="pt-4 text-lg text-gray-700 dark:text-white">
          {name}
        </h3>
        {tags.length > 0 && (
          <div class="flex flex-wrap justify-center gap-1">
            {tags.map(tag => (
              <span class="bg-gray-200 text-gray-800 text-xs font-medium px-2 py-0.5 rounded dark:bg-gray-700 dark:text-gray-300">
                {TAG_CONFIG[tag].label}
              </span>
            ))}
          </div>
        )}
        <p class="pb-2 text-left text-sm text-gray-600 dark:text-slate-300">
          {description}
        </p>
        {(href || source) && (
          <hr class="border-gray-300 dark:border-gray-700 w-full" />
          <p class="pb-4 text-sm text-gray-600 dark:text-slate-300 flex gap-1">
          {
          href && (
            <a href={href} class="hover:text-accent underline" target="_blank" rel="noopener noreferrer">
              Live
            </a>
          )
          }
          {href && source && <span>-</span>}
          {
            source && (
              <a href={source} class="hover:text-accent underline" target="_blank" rel="noopener noreferrer">
                Source
              </a>
            )
          }
          </p>
        )}
      </div>
    </div>
  </div>
  <Fragment slot="noHover">
    <h3 class="pt-6 text-lg text-gray-700 dark:text-white">{name}</h3>
    <p class="py-2 text-sm text-gray-600 dark:text-slate-300">{description}</p>
  </Fragment>
</HoverCard>
