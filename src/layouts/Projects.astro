---
import type { ImageMetadata } from 'astro';
import { getCollection } from 'astro:content';
import ProjectCard from '@/components/cards/ProjectCard.astro';

const IMAGE_ASSET_BASE = '/src/assets/images/';
const imageModules = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/*.{png,jpg,jpeg,webp}', { eager: true });

const projectsCollection = await getCollection('projects');
const projects = projectsCollection
  .map(project => {
    const src = project.data.image.startsWith('http') ? project.data.image : imageModules[`${IMAGE_ASSET_BASE}${project.data.image}`]?.default;
    if (!src) {
      console.warn(`Missing image for project "${project.id}": ${project.data.image}`);
      return null;
    }

    return {
      ...project.data,
      src
    };
  })
  .filter((project): project is NonNullable<typeof project> => project !== null);
---

<div class="projects-wrapper relative my-3" data-collapsed="true">
  <div class="projects-grid grid w-full grid-flow-dense grid-cols-2 gap-4 pt-3 text-center md:grid-cols-4 lg:grid-cols-6">
    {
      projects.map(project => (
        <ProjectCard
          name={project.name}
          href={project.href}
          source={project.source}
          src={project.src}
          description={project.description}
          year={project.year}
          size={project.size}
          hideMobile={project.hideMobile}
          containImage={project.containImage}
          containBackgroundColor={project.containBackgroundColor}
        />
      ))
    }
    <div
      class="hover:text-accent flex flex-col items-center justify-center rounded-lg border-2 border-dashed border-current bg-white/5 px-4 py-6 text-center transition-colors hover:bg-white/10"
    >
      <a href="https://github.com/TetraTsunami" class="text-lg"> See more projects on my GitHub! </a>
    </div>
  </div>
  <button
    class="show-more-btn mx-auto mt-2 block cursor-pointer rounded-lg border-2 border-current px-6 py-2 font-mono text-lg transition-colors hover:bg-white/10"
    type="button"
  >
    Show older
  </button>
</div>

<style>
  .projects-grid {
    transition:
      max-height 0.5s ease-out,
      mask-image 0.3s ease-out;
  }

  .projects-wrapper[data-collapsed='true'] .projects-grid {
    max-height: 520px;
    overflow: hidden;
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }

  @media (min-width: 768px) {
    .projects-wrapper[data-collapsed='true'] .projects-grid {
      max-height: 580px;
    }
  }

  .projects-wrapper[data-collapsed='false'] .projects-grid {
    max-height: 3000px;
    mask-image: none;
  }

  .projects-wrapper[data-collapsed='false'] .show-more-btn {
    display: none;
  }
</style>

<script>
  const wrapper = document.querySelector('.projects-wrapper');
  const btn = wrapper?.querySelector('.show-more-btn');

  btn?.addEventListener('click', () => {
    wrapper?.setAttribute('data-collapsed', 'false');
  });
</script>
